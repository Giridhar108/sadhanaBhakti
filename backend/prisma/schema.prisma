generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  EMAIL
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  spiritualName String        @default("")
  avatarUrl     String?
  provider      AuthProvider  @default(EMAIL)
  passwordHash  String?
  practices     String[]      @default(["japa", "books", "verses"])
  japaRounds    Int           @default(16)
  readingPages  Int           @default(10)
  versesPerWeek Int           @default(1)
  dailyReminder String        @default("05:30")
  japaStartDate String?
  theme         String        @default("soft")
  calendarEvents Json         @default("[]")
  dailyVerses   Json          @default("[{\"id\":\"default-daily-verse\",\"text\":\"Мой дорогой ум, ты избрал путь самосознания, однако, в своем безрассудстве ты считаешь, что купание в претенциозности, обмане и придирчивости, которые сродни ослиной моче, очень очищает.<br> Так ты губишь и себя, и меня. Прошу тебя, остановись! <br>Лучше давай погрузимся в океан нектара любовного служения лотосным стопам Шри&nbsp;Шри&nbsp;Гандхарвики&nbsp;Гиридхари и так принесем нам обоим нескончаемое счастье.\",\"source\":\"Манах Шикша. Стих 6\"}]")
  japaGoalHistory Json        @default("[]")
  isOnboarded   Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lastLoginAt   DateTime      @default(now())
  refreshTokens RefreshToken[]
  audioTracks   AudioTrack[]
  japaDailyProgress JapaDailyProgress[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AudioTrack {
  id           String   @id @default(cuid())
  userId       String
  title        String
  subtitle     String   @default("")
  fileName     String
  originalName String
  mimeType     String
  size         Int
  duration     Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model JapaDailyProgress {
  id        String   @id @default(cuid())
  userId    String
  date      String
  rounds    Int      @default(0)
  goalRounds Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}
